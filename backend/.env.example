APP_FRONTEND_BASE_URL=https://localhost:5173
APP_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/lichsuvn?useSSL=false&connectionTimeZone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace-with-your-local-db-password

APP_MAIL_ENABLED=false
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
# For Gmail app passwords, paste the 16-character value without spaces.
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

APP_AUTH_GOOGLE_CLIENT_ID=

# Facebook OAuth (P2) - get from Meta Developer Console > App Dashboard
APP_AUTH_FACEBOOK_APP_ID=
APP_AUTH_FACEBOOK_APP_SECRET=
# Optional: default is v21.0
# APP_AUTH_FACEBOOK_GRAPH_VERSION=v21.0
